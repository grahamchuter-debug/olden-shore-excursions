{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "olden-shore-excursions",
  "compatibility_date": "2026-05-29",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./out"
  },
  "routes": [
    {
      "pattern": "oldenshoreexcursions.com",
      "custom_domain": true
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
